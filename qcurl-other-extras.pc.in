prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: QCurlOtherExtras
Description: Opt-in non-stable QCurl Other Extras and Preview components
Version: @PROJECT_VERSION@
URL: https://github.com/SunRain/QCurl
Requires: qcurl = @PROJECT_VERSION@
Requires.private: zlib
Libs: -L${libdir} -lQCurlOtherExtras
Cflags: -I${includedir}/qcurl
