# Doxygen configuration for QCurl
#
# 目标：生成可本地查阅的 API 参考文档（不提交生成产物）。
#
# INPUT 不在本文件中 broad 扫描 src/。请先运行：
#   python3 scripts/generate_doxygen_input_from_surface_manifest.py \
#     --manifest tests/public_api/surface_manifest.json \
#     --output build/doxygen/qcurl_api_input.doxy \
#     --check
# 生成的片段会从 tests/public_api/surface_manifest.json 派生 public install surface。

PROJECT_NAME           = "QCurl"
PROJECT_NUMBER         = "1.0.0"

OUTPUT_DIRECTORY       = build
CREATE_SUBDIRS         = NO

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

@INCLUDE               = build/doxygen/qcurl_api_input.doxy
RECURSIVE              = NO
FILE_PATTERNS          = *.h *.hpp
EXCLUDE_PATTERNS       = */private/* *_p.h

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = doxygen
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
