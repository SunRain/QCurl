@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Qt6 REQUIRED COMPONENTS Core Network)

include("${CMAKE_CURRENT_LIST_DIR}/QCurlTargets.cmake")

set(QCurl_Core_FOUND TRUE)
set(QCurl_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@/qcurl")
set(QCurl_BLOCKING_EXTRAS_INCLUDE_DIR "${QCurl_INCLUDE_DIR}")
set(QCurl_TEST_SUPPORT_INCLUDE_DIR "${QCurl_INCLUDE_DIR}")
set(QCurl_OTHER_EXTRAS_INCLUDE_DIR "${QCurl_INCLUDE_DIR}")

foreach(_qcurl_component IN LISTS QCurl_FIND_COMPONENTS)
    if(_qcurl_component STREQUAL "Core")
        set(QCurl_Core_FOUND TRUE)
    elseif(_qcurl_component STREQUAL "BlockingExtras")
        if(EXISTS "${QCurl_INCLUDE_DIR}/QCBlockingNetworkClient.h"
           AND EXISTS "${QCurl_INCLUDE_DIR}/QCBlockingNetworkResult.h")
            set(QCurl_BlockingExtras_FOUND TRUE)
        else()
            set(QCurl_BlockingExtras_FOUND FALSE)
        endif()
    elseif(_qcurl_component STREQUAL "TestSupport")
        if(EXISTS "${QCurl_INCLUDE_DIR}/QCNetworkMockHandler.h"
           AND EXISTS "${QCurl_INCLUDE_DIR}/QCNetworkTestSupport.h")
            set(QCurl_TestSupport_FOUND TRUE)
        else()
            set(QCurl_TestSupport_FOUND FALSE)
        endif()
    elseif(_qcurl_component STREQUAL "OtherExtras")
        if(EXISTS "${QCurl_INCLUDE_DIR}/QCNetworkDiagnostics.h")
            set(QCurl_OtherExtras_FOUND TRUE)
        else()
            set(QCurl_OtherExtras_FOUND FALSE)
        endif()
    else()
        set(QCurl_${_qcurl_component}_FOUND FALSE)
    endif()
endforeach()

check_required_components(QCurl)
